{
	"name": "type-challenges-playground",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"fetch-challenges": "tsx scripts/fetch-challenges.ts",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,mjs,cjs}": [
			"biome check --write --no-errors-on-unmatched"
		],
		"*.{json,css}": [
			"biome format --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"canvas-confetti": "^1.9.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.577.0",
		"marked": "^17.0.4",
		"next": "16.1.6",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"tailwind-merge": "^3.5.0",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@tailwindcss/postcss": "^4",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"monaco-editor": "^0.55.1",
		"shadcn": "^3.8.5",
		"tailwindcss": "^4",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5"
	}
}
